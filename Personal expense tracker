import csv
import os
from datetime import date

FILE = "expenses.csv"
HEADERS = ["id", "date", "category", "amount", "note"]
CATEGORIES = ["Food", "Transport", "Groceries", "Entertainment", "Other"]

def init_file():
    if not os.path.exists(FILE):
        with open(FILE, "w", newline="") as file:
            writer = csv.writer(file)
        writer.writerow(HEADERS)
            
def read_expenses():
    expenses = []

    try:
        with open(FILE, "r", newline="") as file:
            reader = csv.DictReader(file)

            # Check if headers are missing
            if reader.fieldnames != HEADERS:
                return []

            for row in reader:
                row["id"] = int(row["id"])
                row["amount"] = float(row["amount"])
                expenses.append(row)

    except FileNotFoundError:
        return []

    return expenses

def get_next_id(expenses):
    if not expenses:
        return 1

    return max(expenses, key=lambda e: e["id"])["id"] + 1

def add_expense():
    expenses = read_expenses()

    # Category input
    category = input(f"Enter category {CATEGORIES}: ")

    if category not in CATEGORIES:
        print("Invalid category!")
        return

    # Amount input
    try:
        amount = float(input("Enter amount: "))

        if amount <= 0:
            print("Amount must be positive!")
            return

    except ValueError:
        print("Invalid amount!")
        return

    # Note input
    note = input("Enter note (optional): ").strip()
    if note == "":
        note = "—"

    # Auto-generated fields
    expense_id = get_next_id(expenses)
    expense_date = str(date.today())

    # Write to CSV file
    with open(FILE, "a", newline="") as file:
        writer = csv.writer(file)

        writer.writerow([
            expense_id,
            expense_date,
            category,
            amount,
            note
        ])

    # Confirmation
    print("\nExpense added successfully!")
    print(f"ID: {expense_id}")
    print(f"Date: {expense_date}")
    print(f"Category: {category}")
    print(f"Amount: {amount}")
    print(f"Note: {note}")
def view_expenses(expenses):
    if not expenses:
        print("No expenses found.")
        return

    print(f"{'ID':<5} {'Date':<12} {'Category':<15} {'Amount':<10} {'Note'}")
    print("-" * 60)

    for expense in expenses:
        print(
            f"{expense['id']:<5} "
            f"{expense['date']:<12} "
            f"{expense['category']:<15} "
            f"{expense['amount']:<10.2f} "
            f"{expense['note']}"
        )

def filter_by_category(expenses):
    category = input("Enter category: ").strip().lower()

    filtered = []

    for expense in expenses:
        if expense["category"].lower() == category:
            filtered.append(expense)

    if filtered:
        view_expenses(filtered)
    else:
        print("No expenses found for this category.")
     
def monthly_summary(expenses):
    if not expenses:
        print("No expenses recorded yet.")
        return

    summary = {}

    # Build summary dictionary
    for expense in expenses:
        category = expense["category"]
        amount = expense["amount"]

        if category not in summary:
            summary[category] = {
                "total": 0,
                "count": 0
            }

        summary[category]["total"] += amount
        summary[category]["count"] += 1

 # Print table
    print(f"{'Category':<15} {'Count':<10} {'Total'}")
    print("-" * 40)

    for category, data in summary.items():
        print(
            f"{category:<15} "
            f"{data['count']:<10} "
            f"{data['total']:.2f}"
        )

    # Grand total
    grand_total = sum(data["total"] for data in summary.values())

    # Biggest spend category
    biggest_spend = max(summary, key=lambda c: summary[c]["total"])

    # Most frequent category
    most_frequent = max(summary, key=lambda c: summary[c]["count"])

    print("\n--- Summary ---")
    print(f"Grand Total: {grand_total:.2f}")
    print(f"Biggest Spend Category: {biggest_spend}")
    print(f"Most Frequent Category: {most_frequent}")

def delete_expense():
    expenses = read_expenses()

    try:
        delete_id = int(input("Enter ID to delete: "))

    except ValueError:
        print("Invalid ID.")
        return

    # Check if ID exists
    found = False
    updated_expenses = []

    for expense in expenses:
        if expense["id"] == delete_id:
            found = True
        else:
            updated_expenses.append(expense)

    if not found:
        print("ID not found.")
        return
 # Rewrite file
    with open(FILE, "w", newline="") as file:
        writer = csv.writer(file)

        # Write headers
        writer.writerow(HEADERS)

        # Write remaining rows
        for expense in updated_expenses:
            writer.writerow([
                expense["id"],
                expense["date"],
                expense["category"],
                expense["amount"],
                expense["note"]
            ])

    print("Expense deleted successfully.")

def main():
    init_file()

    while True:
        print("\n===== Expense Tracker =====")
        print("1. Add Expense")
        print("2. View Expenses")
        print("3. Filter by Category")
        print("4. Monthly Summary")
        print("5. Delete Expense")
        print("6. Exit")

        choice = input("Enter your choice: ").strip()

        if choice == "1":
            add_expense()

        elif choice == "2":
            expenses = read_expenses()
            view_expenses(expenses)

        elif choice == "3":
            expenses = read_expenses()
            filter_by_category(expenses)
        elif choice == "4":
            expenses = read_expenses()
            monthly_summary(expenses)

        elif choice == "5":
            delete_expense()

        elif choice == "6":
            print("Exiting Expense Tracker. Goodbye!")
            break

        else:
            print("Invalid choice. Please try again.")


if __name__ == "__main__":
    main()